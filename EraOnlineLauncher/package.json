{
  "name": "era-online-launcher",
  "version": "1.0.15",
  "description": "Era Online Game Launcher",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:dir": "electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "com.eraonline.launcher",
    "productName": "Era Online Launcher",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "shortcutName": "Era Online"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [],
    "publish": {
      "provider": "generic",
      "url": "https://raw.githubusercontent.com/blueavlo-hash/EraOnlinePort/main/public/launcher"
    }
  },
  "devDependencies": {
    "electron": "33.4.11",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {}
}
